---
import '@fontsource/space-mono';
import '@fontsource/inter';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="holyfuckingshit40000: The Second Pressing" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/hfs40k/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-holy-black text-holy-white font-mono antialiased">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <header class="border-b border-holy-grey pb-8 mb-12">
        <h1 class="text-4xl font-bold uppercase tracking-tighter sm:text-6xl md:text-7xl">
          <a href="/hfs40k/" class="hover:text-holy-grey transition-colors">
            holyfuckingshit40000<span class="text-red-600">:</span><br/>
            The Second Pressing
          </a>
        </h1>
        <p class="mt-4 text-sm text-holy-grey uppercase tracking-widest">
          Archiving the underground since 2008 // Resurrected 2026
        </p>
      </header>
      <main>
		    <slot />
      </main>
      <footer class="mt-20 pt-8 border-t border-holy-grey text-xs text-holy-grey uppercase flex justify-between">
        <p>© 2026 holyfuckingshit40000: The Second Pressing</p>
        <p>A static monument to a legendary blog</p>
      </footer>
    </div>
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
  ::selection {
    background-color: #dc2626;
    color: white;
  }
</style>
